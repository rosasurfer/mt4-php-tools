#
# Copy this file to "/.env" and adjust it to customize your default values.
#

# PHP: An alternative PHP binary to be used by scripts in "/bin".
#PHP=

# PHPStan: An alternative PHPStan executable to be used by "/bin/phpstan".
#PHPSTAN=

# PHPStan: String containing environment variables to export to PHPStan (separated by spaces).
#PHPSTAN_EXPORT_VARS=''
